{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommitTypeAll(chore)"],
  "packageRules": [
    {
      "description": "Auto-merge every minor/patch update once CI passes; majors still open a PR for review",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Group GitHub Actions bumps into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 6am on monday"]
  }
}
